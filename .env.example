APP_NAME=Organizz
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# E-mails (séparés par des virgules) promus super admin à l’inscription (voir config/organizz.php).
# SUPER_ADMIN_EMAILS=raphael.degand@ldmedia.be

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Recommandé en local : sqlite (pas besoin d’Internet). En prod / Vercel : PostgreSQL (Supabase) — pas de SQLite sur Vercel.
# Sans DB_CONNECTION : Supabase si SUPABASE_DB_URL ; sinon pgsql si DATABASE_URL / POSTGRES_URL (ex. Vercel Postgres).
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# --- Supabase (PostgreSQL) : tables créées par « php artisan migrate » ---
# Prérequis PHP : extension pdo_pgsql (ex. brew install php puis vérifier php -m | grep pdo_pgsql)
# Dashboard → Settings → Database : mot de passe + « Connection string » mode Session ou Direct.
#
# Méthode recommandée : URI directe (port 5432, hôte db.<project_ref>.supabase.co)
# SUPABASE_DB_URL="postgresql://postgres:[MOT_DE_PASSE_DB]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"
#
# Ou variables séparées :
# DB_CONNECTION=supabase
# SUPABASE_DB_HOST=db.[PROJECT_REF].supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_DATABASE=postgres
# SUPABASE_DB_USERNAME=postgres
# SUPABASE_DB_PASSWORD=
# SUPABASE_DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Supabase — API (Settings → API)
# SUPABASE_URL=https://<project_ref>.supabase.co
SUPABASE_URL=
# Clé « anon » / public (JWT role: anon) — Vite & JS client uniquement
SUPABASE_ANON_KEY=
# Clé « service_role » (JWT role: service_role) — backend Laravel uniquement, ne pas dupliquer la clé anon
SUPABASE_SERVICE_ROLE_KEY=

VITE_SUPABASE_URL="${SUPABASE_URL}"
VITE_SUPABASE_ANON_KEY="${SUPABASE_ANON_KEY}"

# ------------------------------------------------------------------
# Vercel (production serverless) - valeurs recommandées
# ------------------------------------------------------------------
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://organizz-p8fh.vercel.app
# LOG_CHANNEL=stderr
# SESSION_DRIVER=cookie
# SESSION_SECURE_COOKIE=true
# CACHE_STORE=array
# QUEUE_CONNECTION=sync
#
# Base Supabase (production):
# DB_CONNECTION=supabase
# SUPABASE_DB_URL="postgresql://postgres:[MOT_DE_PASSE]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"
# (ou variables SUPABASE_DB_HOST/PORT/DATABASE/USERNAME/PASSWORD)
